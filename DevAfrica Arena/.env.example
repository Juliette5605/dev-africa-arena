APP_NAME="DevAfrica Arena"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Abidjan
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DONNÉES
# Option 1 : SQLite (zéro config, parfait pour démarrer)
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
# DB_DATABASE=/chemin/absolu/vers/database/database.sqlite

# ─────────────────────────────────────────────────────────────────────────────
# Option 2 : MySQL / MariaDB (décommenter pour la production)
# ─────────────────────────────────────────────────────────────────────────────
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=devafrica_arena
# DB_USERNAME=root
# DB_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Option 3 : PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=devafrica_arena
# DB_USERNAME=postgres
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=devafrica_

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL
# Option 1 : Log (développement — les emails s'affichent dans storage/logs)
# ─────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="arena@devafrica.tg"
MAIL_FROM_NAME="DevAfrica Arena"

# ─────────────────────────────────────────────────────────────────────────────
# Option 2 : Mailtrap (tests — créer compte gratuit sur mailtrap.io)
# ─────────────────────────────────────────────────────────────────────────────
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=votre_username_mailtrap
# MAIL_PASSWORD=votre_password_mailtrap
# MAIL_ENCRYPTION=tls

# ─────────────────────────────────────────────────────────────────────────────
# Option 3 : Gmail (production)
# Créer un mot de passe d'application Gmail : myaccount.google.com/apppasswords
# ─────────────────────────────────────────────────────────────────────────────
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=votre@gmail.com
# MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
# MAIL_ENCRYPTION=tls

VITE_APP_NAME="${APP_NAME}"
